// HubSpot Sync Application - Database Schema
// PostgreSQL with Prisma ORM

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// Stores HubSpot OAuth credentials for each connected portal
model User {
  id              String   @id @default(cuid())
  hubspotPortalId String   @unique
  portalName      String?
  accessToken     String
  refreshToken    String
  tokenExpiresAt  DateTime
  scopes          String?
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  contacts  Contact[]
  syncJobs  SyncJob[]
}

// Stores synchronized HubSpot contacts
model Contact {
  id              String   @id @default(cuid())
  hubspotId       String   @unique
  userId          String
  email           String?
  firstName       String?
  lastName        String?
  phone           String?
  company         String?
  jobTitle        String?
  lifecycleStage  String?
  leadStatus      String?
  city            String?
  country         String?
  hsCreatedAt     DateTime?
  hsUpdatedAt     DateTime?
  lastSyncedAt    DateTime @default(now())
  createdAt       DateTime @default(now())
  updatedAt       DateTime @updatedAt

  user  User   @relation(fields: [userId], references: [id], onDelete: Cascade)
  notes Note[]

  @@index([userId])
  @@index([email])
  @@index([lastSyncedAt])
}

// Notes created in our app, synced to HubSpot as engagements
model Note {
  id                   String    @id @default(cuid())
  hubspotEngagementId  String?   @unique
  contactId            String
  body                 String
  syncedToHubspot      Boolean   @default(false)
  syncAttempts         Int       @default(0)
  lastSyncError        String?
  lastSyncAttempt      DateTime?
  createdAt            DateTime  @default(now())
  updatedAt            DateTime  @updatedAt

  contact Contact @relation(fields: [contactId], references: [id], onDelete: Cascade)

  @@index([contactId])
  @@index([syncedToHubspot])
  @@index([createdAt])
}

// Tracks background sync jobs for progress monitoring
model SyncJob {
  id            String    @id @default(cuid())
  userId        String
  type          String
  status        String    @default("pending")
  totalItems    Int?
  processed     Int       @default(0)
  failed        Int       @default(0)
  cursor        String?
  startedAt     DateTime?
  completedAt   DateTime?
  error         String?
  metadata      String?
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId, status])
  @@index([type, status])
}
