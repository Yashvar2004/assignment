{
  "name": "hubspot-sync-backend",
  "version": "1.0.0",
  "description": "HubSpot integration backend with OAuth, contact sync, and notes",
  "main": "dist/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "prisma generate && tsc",
    "start": "node dist/index.js",
    "db:generate": "prisma generate",
    "db:push": "prisma db push",
    "db:migrate": "prisma migrate dev",
    "db:studio": "prisma studio",
    "worker:contacts": "tsx src/workers/contact-sync.worker.ts",
    "worker:notes": "tsx src/workers/note-sync.worker.ts"
  },
  "dependencies": {
    "@prisma/client": "^6.9.0",
    "axios": "^1.7.9",
    "bullmq": "^5.31.0",
    "cors": "^2.8.5",
    "dotenv": "^16.4.7",
    "express": "^4.21.2",
    "express-rate-limit": "^7.5.0",
    "helmet": "^8.0.0",
    "ioredis": "^5.4.2",
    "jsonwebtoken": "^9.0.2",
    "morgan": "^1.10.0",
    "winston": "^3.17.0",
    "zod": "^3.24.1"
  },
  "devDependencies": {
    "@types/cors": "^2.8.17",
    "@types/express": "^5.0.0",
    "@types/jsonwebtoken": "^9.0.7",
    "@types/morgan": "^1.9.9",
    "@types/node": "^22.10.5",
    "prisma": "^6.9.0",
    "tsx": "^4.19.2",
    "typescript": "^5.7.3"
  }
}
