{
  "version": 2,
  "builds": [
    {
      "src": "backend/api/index.js",
      "use": "@vercel/node",
      "config": {
        "includeFiles": ["backend/node_modules/**", "backend/prisma/**"]
      }
    }
  ],
  "routes": [
    {
      "src": "/api/(.*)",
      "dest": "backend/api/index.js"
    },
    {
      "src": "/health",
      "dest": "backend/api/index.js"
    },
    {
      "src": "/test",
      "dest": "backend/api/index.js"
    },
    {
      "src": "/(.*)",
      "dest": "backend/api/index.js"
    }
  ]
}
